rules_version = '2';

// First pass: permissive but auth-gated. Tightening (per-room ACLs, hand secrecy
// via authUid match) happens after the room/hand schema lands.
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared with the scorekeeper. Keep open during early rollout to avoid
    // breaking the existing app — revisit before public launch.
    match /players/{playerId} {
      allow read, write: if true;
    }
    match /games/{gameId} {
      allow read, write: if true;
    }

    // Multiplayer state. Anonymous auth required so opponents can't read each
    // other's hands once we tighten rules below.
    match /rooms/{code} {
      allow read, write: if request.auth != null;

      match /players/{playerName} {
        allow read, write: if request.auth != null;
      }

      match /hands/{playerName} {
        // TODO(step 5): allow read only when request.auth.uid matches the
        // authUid stored on rooms/{code}/players/{playerName}.
        allow read, write: if request.auth != null;
      }
    }
  }
}
